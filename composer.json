{
    "name": "logstream/laravel-sdk",
    "description": "Laravel SDK for LogStream — send your application logs to your self-hosted LogStream instance in real time",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "monolog", "logging", "logstream", "log aggregator"],
    "homepage": "https://github.com/cloud-dfe/logstream-sdk",
    "authors": [
        {
            "name": "Cleverton Souza",
            "email": "cleverton.marodim@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "LogStream\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
